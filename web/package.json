{
  "name": "saessagi-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "sync-assets": "bash scripts/sync-character-assets.sh",
    "copy-preload": "cp electron/preload.cjs electron-dist/preload.cjs",
    "predev": "npm run sync-assets",
    "dev": "vite",
    "prebuild": "npm run sync-assets",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:compile": "tsc -p tsconfig.electron.json && npm run copy-preload",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && npm run electron:compile && NODE_ENV=development electron .\"",
    "electron:build": "npm run prebuild && tsc --noEmit && ELECTRON_BUILD=1 vite build && tsc -p tsconfig.electron.json && npm run copy-preload && electron-builder",
    "electron:build:win": "npm run prebuild && tsc --noEmit && ELECTRON_BUILD=1 vite build && tsc -p tsconfig.electron.json && npm run copy-preload && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.427.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.1.2",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "kr.company.saessagi",
    "productName": "새싹이",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**",
      "electron-dist/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    }
  }
}
